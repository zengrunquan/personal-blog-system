<?xml version="1.0" encoding="UTF-8"?>
<!-- Log4j2 配置文件 - 解决 Druid 连接池缺少日志实现的警告 -->
<Configuration status="WARN">
    <Appenders>
        <!-- 控制台输出 -->
        <Console name="Console" target="SYSTEM_OUT">
            <PatternLayout pattern="%d{yyyy-MM-dd HH:mm:ss} [%level] %logger{36} - %msg%n"/>
        </Console>
    </Appenders>
    <Loggers>
        <!-- Druid 连接池日志级别设为 WARN，减少不必要的输出 -->
        <Logger name="com.alibaba.druid" level="WARN" additivity="false">
            <AppenderRef ref="Console"/>
        </Logger>
        <!-- 根日志级别 -->
        <Root level="INFO">
            <AppenderRef ref="Console"/>
        </Root>
    </Loggers>
</Configuration>
