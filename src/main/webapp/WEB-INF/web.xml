<?xml version="1.0" encoding="UTF-8"?>
<web-app xmlns="http://xmlns.jcp.org/xml/ns/javaee"
         xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
         xsi:schemaLocation="http://xmlns.jcp.org/xml/ns/javaee
                             http://xmlns.jcp.org/xml/ns/javaee/web-app_4_0.xsd"
         version="4.0">

    <display-name>个人博客系统</display-name>
    <description>JavaWeb课程期末项目 - 个人博客系统</description>

    <!-- ================================================ -->
    <!-- 编码过滤器 -->
    <!-- ================================================ -->
    <filter>
        <filter-name>EncodingFilter</filter-name>
        <filter-class>com.blog.filter.EncodingFilter</filter-class>
    </filter>
    <filter-mapping>
        <filter-name>EncodingFilter</filter-name>
        <url-pattern>/*</url-pattern>
    </filter-mapping>

    <!-- ================================================ -->
    <!-- 登录拦截过滤器 -->
    <!-- ================================================ -->
    <filter>
        <filter-name>AuthFilter</filter-name>
        <filter-class>com.blog.filter.AuthFilter</filter-class>
    </filter>
    <filter-mapping>
        <filter-name>AuthFilter</filter-name>
        <url-pattern>/user/*</url-pattern>
    </filter-mapping>
    <filter-mapping>
        <filter-name>AuthFilter</filter-name>
        <url-pattern>/article/add</url-pattern>
    </filter-mapping>
    <filter-mapping>
        <filter-name>AuthFilter</filter-name>
        <url-pattern>/article/edit</url-pattern>
    </filter-mapping>
    <filter-mapping>
        <filter-name>AuthFilter</filter-name>
        <url-pattern>/article/delete</url-pattern>
    </filter-mapping>
    <!-- 上传接口会写入服务器文件系统，必须复用登录态边界，避免匿名用户上传任意文件 -->
    <filter-mapping>
        <filter-name>AuthFilter</filter-name>
        <url-pattern>/article/uploadCover</url-pattern>
    </filter-mapping>
    <filter-mapping>
        <filter-name>AuthFilter</filter-name>
        <url-pattern>/article/uploadFile</url-pattern>
    </filter-mapping>
    <filter-mapping>
        <filter-name>AuthFilter</filter-name>
        <url-pattern>/article/batchUpload</url-pattern>
    </filter-mapping>
    <!-- 下载接口只允许登录用户访问，避免未登录用户枚举附件文件名 -->
    <filter-mapping>
        <filter-name>AuthFilter</filter-name>
        <url-pattern>/article/download</url-pattern>
    </filter-mapping>
    <filter-mapping>
        <filter-name>AuthFilter</filter-name>
        <url-pattern>/comment/*</url-pattern>
    </filter-mapping>

    <!-- ================================================ -->
    <!-- 管理员拦截过滤器 -->
    <!-- ================================================ -->
    <filter>
        <filter-name>AdminFilter</filter-name>
        <filter-class>com.blog.filter.AdminFilter</filter-class>
    </filter>
    <filter-mapping>
        <filter-name>AdminFilter</filter-name>
        <url-pattern>/admin/*</url-pattern>
    </filter-mapping>
    <!-- 导出包含全站文章数据，只允许后台管理员访问 -->
    <filter-mapping>
        <filter-name>AdminFilter</filter-name>
        <url-pattern>/article/export</url-pattern>
    </filter-mapping>

    <!-- ================================================ -->
    <!-- 在线用户监听器 -->
    <!-- ================================================ -->
    <listener>
        <listener-class>com.blog.listener.OnlineUserListener</listener-class>
    </listener>

    <!-- ================================================ -->
    <!-- Session配置 -->
    <!-- ================================================ -->
    <session-config>
        <session-timeout>30</session-timeout>
    </session-config>

    <!-- ================================================ -->
    <!-- 欢迎页面 -->
    <!-- ================================================ -->
    <welcome-file-list>
        <welcome-file>index.jsp</welcome-file>
    </welcome-file-list>

    <!-- ================================================ -->
    <!-- 错误页面 -->
    <!-- ================================================ -->
    <error-page>
        <error-code>404</error-code>
        <location>/error/404.jsp</location>
    </error-page>
    <error-page>
        <error-code>500</error-code>
        <location>/error/500.jsp</location>
    </error-page>

</web-app>
